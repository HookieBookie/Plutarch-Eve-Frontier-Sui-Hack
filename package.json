{
  "name": "plutarch-eve-frontier",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Plutarch — Corporate management dApp for EVE Frontier on Sui",
  "scripts": {
    "dev": "vite",
    "dev:utopia": "cross-env VITE_EVE_TENANT=utopia vite",
    "dev:stillness": "cross-env VITE_EVE_TENANT=stillness vite",
    "build": "tsc && vite build",
    "build:utopia": "cross-env VITE_EVE_TENANT=utopia tsc && cross-env VITE_EVE_TENANT=utopia vite build",
    "build:stillness": "cross-env VITE_EVE_TENANT=stillness tsc && cross-env VITE_EVE_TENANT=stillness vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "tunnel": "cloudflared tunnel --url http://localhost:5174"
  },
  "dependencies": {
    "@evefrontier/dapp-kit": "^0.1.2",
    "@mysten/dapp-kit-core": "^1.0.4",
    "@mysten/dapp-kit-react": "^1.0.2",
    "@mysten/sui": "^2.4.0",
    "@radix-ui/colors": "^3.0.0",
    "@radix-ui/react-icons": "^1.3.0",
    "@radix-ui/themes": "^3.2.1",
    "@tanstack/react-query": "^5.80.2",
    "better-sqlite3": "^12.8.0",
    "drizzle-orm": "^0.45.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^19.2.4",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.33.1",
    "@typescript-eslint/parser": "^8.33.1",
    "@vitejs/plugin-react-swc": "^3.10.1",
    "cross-env": "^10.1.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["better-sqlite3", "esbuild"]
  },
  "packageManager": "pnpm@10.17.0+sha512.fce8a3dd29a4ed2ec566fb53efbb04d8c44a0f05bc6f24a73046910fb9c3ce7afa35a0980500668fa3573345bd644644fa98338fa168235c80f4aa17aa17fbef"
}
